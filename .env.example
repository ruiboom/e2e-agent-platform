# ── Canonical + lineage store (Postgres 16 + pgvector + pg_trgm) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agent_platform

# ── Service URLs ──
MODEL_ROUTER_URL=http://localhost:8789
COST_TRACKER_URL=http://localhost:8787
FEEDBACK_TRACKER_URL=http://localhost:8788
GROUND_URL=http://localhost:8790
BUILD_RUNTIME_URL=http://localhost:8791

# Browser-exposed URLs for the console (the cost iframe + feedback widget run
# client-side). Mirrored in apps/console/.env.local.
NEXT_PUBLIC_COST_TRACKER_URL=http://localhost:8787
NEXT_PUBLIC_FEEDBACK_TRACKER_URL=http://localhost:8788

# ── Auth (Phase 0 dev stub) ──
# Switch to "oidc" once an IdP is wired. getSession() reads this seam.
SESSION_PROVIDER=dev-stub
SESSION_SECRET=dev-only-change-me

# ── Model providers (LiteLLM passthrough; Phase 0 ships Anthropic) ──
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# Default logical model for the router. Must resolve in cost-tracker's pricing
# table (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5).
MODEL_ROUTER_DEFAULT_MODEL=claude-haiku-4-5
