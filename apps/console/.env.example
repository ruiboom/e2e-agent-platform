# Console env (Next.js loads .env files from this directory).
# Copy to .env.local for local dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/agent_platform
MODEL_ROUTER_URL=http://localhost:8789
SESSION_SECRET=dev-only-change-me

# Browser-exposed (client-side cost iframe + feedback widget).
NEXT_PUBLIC_COST_TRACKER_URL=http://localhost:8787
NEXT_PUBLIC_FEEDBACK_TRACKER_URL=http://localhost:8788
