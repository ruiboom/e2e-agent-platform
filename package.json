{
  "name": "agent-platform",
  "private": true,
  "version": "0.0.0",
  "description": "Agent Platform backbone — monorepo (Phase 0 walking skeleton)",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter @agent-platform/console dev",
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "db:migrate": "pnpm --filter @agent-platform/db migrate",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
